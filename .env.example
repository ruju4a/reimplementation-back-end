# Copy to .env.production on the server:
#   cp .env.example .env.production
# Then edit MYSQL_ROOT_PASSWORD (and DATABASE_URL password to match).
#
# REQUIRED in production — generate once (never commit real values):
#   openssl rand -hex 64

SECRET_KEY_BASE=replace_with_openssl_rand_hex_64_output

MYSQL_ROOT_PASSWORD=expertiza

# Host must be "db" (Docker service name), not localhost.
DATABASE_URL=mysql2://root:expertiza@db:3306/reimplementation?

# Optional: omit or leave unset to skip Redis cache entirely (Rails default cache).
# If set, use redis URL matching the redis service hostname:
# CACHE_STORE=redis://redis:6379/0
